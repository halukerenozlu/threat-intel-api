# .env template

# Server
SERVER_PORT=8080
ENVIRONMENT=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=threat_intel
DB_SSLMODE=disable

# JWT
JWT_SECRET=
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h

# External threat intelligence APIs
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
OTX_API_KEY=

# LLM summarization service (Anthropic Claude API)
ANTHROPIC_API_KEY=

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60