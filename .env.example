# Bu dosyayı kopyalayıp .env olarak kaydet, gerçek değerleri doldur
# cp .env.example .env

# Sunucu
SERVER_PORT=8080
ENVIRONMENT=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=threat_intel
DB_SSLMODE=disable

# JWT
JWT_SECRET=
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h

# Harici tehdit istihbaratı API'leri
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
OTX_API_KEY=

# LLM özetleme servisi (Anthropic Claude API)
ANTHROPIC_API_KEY=

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
